(1 row)

-- Повторный вызов — fasttruncate (false)
INSERT INTO temp_calc_main (f_division, n_amount) VALUES (1, 100.50);
SELECT count(*) = 1 AS has_data FROM temp_calc_main;
 has_data 
----------
