(1 row)

SELECT create_temp_table('temp_calc_main') AS second_call;
 second_call 
-------------
 f
(1 row)

SELECT count(*) = 0 AS cleared FROM temp_calc_main;
 cleared 
---------
 t
(1 row)

-- Индексы работают после fasttruncate
INSERT INTO temp_calc_main (f_division, n_amount)
SELECT g % 10, g * 1.5 FROM generate_series(1, 1000) g;
SET enable_seqscan = off;
SET enable_bitmapscan = off;
SELECT count(*) > 0 AS idx_works FROM temp_calc_main WHERE f_division = 5;
 idx_works 
-----------
 t
(1 row)

RESET enable_seqscan;
RESET enable_bitmapscan;
-- CHECK constraint жив
DO $$ BEGIN
    INSERT INTO temp_calc_main (c_status) VALUES ('invalid');
    RAISE EXCEPTION 'CHECK should have failed';
EXCEPTION WHEN check_violation THEN NULL;
END $$;
-- IDENTITY работает
INSERT INTO temp_calc_main (f_division) VALUES (1);
SELECT link IS NOT NULL AS identity_works
FROM temp_calc_main ORDER BY link DESC LIMIT 1;
 identity_works 
----------------
