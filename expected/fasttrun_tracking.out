DO $$
DECLARE i int;
BEGIN
    FOR i IN 1..5 LOOP
        PERFORM create_temp_table('temp_calc_main');
        PERFORM create_temp_table('temp_calc_detail');
        PERFORM create_temp_table('temp_payment_batch');
        INSERT INTO temp_calc_main (f_division) VALUES (i);
    END LOOP;
END $$;
SELECT count(*) = 1 AS last_insert_only FROM temp_calc_main;
