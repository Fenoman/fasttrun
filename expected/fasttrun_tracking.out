--
-- fasttrun_tracking — тесты трекинга CREATE TEMP TABLE и прогрева.
--
-- Тест работает в обоих режимах:
--   * без shared_preload_libraries → graceful degradation
--   * с shared_preload_libraries → полный трекинг через GUC
--
CREATE EXTENSION IF NOT EXISTS fasttrun;
-- ======================================================================
-- Подготовка: схема dummy_tmp + чучела + create_temp_table()
-- ======================================================================
CREATE SCHEMA IF NOT EXISTS dummy_tmp;
CREATE TABLE dummy_tmp.temp_calc_main (
    link bigint GENERATED BY DEFAULT AS IDENTITY,
    f_division int NOT NULL DEFAULT 0,
    d_date timestamp NOT NULL DEFAULT now(),
    n_amount numeric(15,2),
    c_status text DEFAULT 'new' CHECK (c_status IN ('new','done','error'))
);
CREATE INDEX ON dummy_tmp.temp_calc_main (f_division);
CREATE INDEX ON dummy_tmp.temp_calc_main (d_date);
CREATE TABLE dummy_tmp.temp_calc_detail (
    link bigint GENERATED BY DEFAULT AS IDENTITY,
    f_main bigint NOT NULL,
    n_value numeric(15,4),
    c_note text
);
CREATE INDEX ON dummy_tmp.temp_calc_detail (f_main);
CREATE TABLE dummy_tmp.temp_report_header (
    id serial,
    f_division int,
    d_period_start date,
    d_period_end date,
    c_title text
);
CREATE INDEX ON dummy_tmp.temp_report_header (f_division);
CREATE TABLE dummy_tmp.temp_payment_batch (
    link bigint GENERATED BY DEFAULT AS IDENTITY,
    f_subscr bigint,
    d_payment date,
    n_amount numeric(15,2),
    c_purpose text,
    f_source smallint DEFAULT 1
);
CREATE INDEX ON dummy_tmp.temp_payment_batch (f_subscr);
CREATE TABLE dummy_tmp.temp_meter_data (
    f_meter bigint NOT NULL,
    d_reading date,
    n_value numeric(12,3),
    b_estimated boolean DEFAULT false
);
CREATE TABLE dummy_tmp.temp_wide_report (
    f_division int,
    c_name text,
    n_col01 numeric, n_col02 numeric, n_col03 numeric, n_col04 numeric,
    n_col05 numeric, n_col06 numeric, n_col07 numeric, n_col08 numeric
);
-- Упрощённая create_temp_table
CREATE OR REPLACE FUNCTION public.create_temp_table(
    _c_temp_table text,
    _c_dummy_schema text DEFAULT 'dummy_tmp'
) RETURNS boolean
LANGUAGE plpgsql AS $_$
DECLARE
    _b_exists  bool;
    _i_temp    int2;
    _i_dummy   int2;
BEGIN
    _c_temp_table := lower(_c_temp_table);

    SELECT true, c.relnatts
    INTO _b_exists, _i_temp
    FROM pg_catalog.pg_class c
    WHERE c.relnamespace = pg_my_temp_schema()
      AND c.relname = _c_temp_table;

    IF _b_exists THEN
        SELECT c.relnatts INTO _i_dummy
        FROM pg_catalog.pg_class c
        JOIN pg_catalog.pg_namespace n ON n.oid = c.relnamespace
        WHERE n.nspname = _c_dummy_schema AND c.relname = _c_temp_table;

        IF _i_temp IS DISTINCT FROM _i_dummy THEN
            EXECUTE format('DROP TABLE %I', _c_temp_table);
            _b_exists := false;
        END IF;
    END IF;

    IF _b_exists THEN
        PERFORM public.fasttruncate(_c_temp_table);
        RETURN false;
    END IF;

    EXECUTE format(
        'CREATE TEMP TABLE %I (LIKE %I.%I INCLUDING DEFAULTS INCLUDING GENERATED INCLUDING IDENTITY INCLUDING CONSTRAINTS INCLUDING INDEXES)',
        _c_temp_table, _c_dummy_schema, _c_temp_table
    );

    RETURN true;
END;
$_$;
-- ======================================================================
-- 1. Все функции трекинга не падают (с shmem и без)
-- ======================================================================
-- Сброс предыдущей статистики (если shmem есть)
SELECT fasttrun_reset_temp_stats();
