-- ======================================================================
-- 2. create_temp_table работает с чучелами: CREATE, fasttruncate,
--    индексы, CHECK, IDENTITY
-- ======================================================================
-- Первый вызов — создание (true)
SELECT create_temp_table('temp_calc_main') AS first_create;
 first_create 
--------------
